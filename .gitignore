# Build output
bin/
dist/
coverage.out

# Corpus — third-party job specs scraped from public repos, each under its own
# license. Ignore ALL corpus content and check in only the provenance manifests,
# so the corpus is reproducible from source (scripts/corpus/fetch_corpus.py)
# without re-hosting other people's files.
testdata/corpus/**
!testdata/corpus/**/
!testdata/corpus/**/manifest.json
!testdata/pairs/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.env

# Editor
.DS_Store
*.swp
*.swo
.idea/
.vscode/
